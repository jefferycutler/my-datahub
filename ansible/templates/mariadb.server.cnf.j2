# Ansible-managed: MariaDB base server configuration (common to primary and replica)
# Primary- and replica-specific options are in separate .cnf files under
# /etc/mysql/mariadb.conf.d/ deployed by Setup_MariaDB_Primary/Replica.yaml.

[mysqld]
# server_id must be unique across the replication pair.
# Derived from the host's 1-based position in the Ansible `databases` group.
server_id               = {{ groups['databases'].index(inventory_hostname) + 1 }}

# Listen on all interfaces so the replica and MaxScale can reach this node.
bind-address            = 0.0.0.0
port                    = {{ mariadb_port }}
datadir                 = {{ mariadb_datadir }}

# Character set / collation
character-set-server    = utf8mb4
collation-server        = utf8mb4_unicode_ci

# InnoDB
innodb_buffer_pool_size = 256M
innodb_file_per_table   = 1

# Logging
log_error               = /var/log/mysql/error.log
slow_query_log          = 1
slow_query_log_file     = /var/log/mysql/slow.log
long_query_time         = 2

[client]
default-character-set   = utf8mb4
