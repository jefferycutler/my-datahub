// JAAS config for Kafka broker SASL/SCRAM authentication.
// Specifies only the inter-broker login credential (dhadmin).
// SCRAM accounts for dhpub and dhconsume live in the metadata log, not here —
// they were seeded at storage format time via --add-scram.

KafkaServer {
    org.apache.kafka.common.security.scram.ScramLoginModule required
    username="{{ kafka_admin_user }}"
    password="{{ kafka_admin_pw }}";
};
